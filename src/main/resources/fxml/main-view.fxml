<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
			fx:controller="com.edithj.ui.controller.MainController"
			styleClass="app-shell">
	<top>
		<VBox spacing="10.0" styleClass="app-header" BorderPane.alignment="CENTER_LEFT">
			<padding>
				<Insets top="20.0" right="24.0" bottom="16.0" left="24.0"/>
			</padding>
			<Label text="EDITH-J" styleClass="app-title"/>
			<Label text="JavaFX AI desktop assistant shell" styleClass="app-subtitle"/>
		</VBox>
	</top>
	<left>
		<VBox spacing="12.0" prefWidth="220.0" styleClass="sidebar" BorderPane.alignment="TOP_CENTER">
			<padding>
				<Insets top="20.0" right="16.0" bottom="20.0" left="16.0"/>
			</padding>
			<Button text="Chat" onAction="#showChatView" maxWidth="Infinity" styleClass="nav-button"/>
			<Button text="Notes" onAction="#showNotesView" maxWidth="Infinity" styleClass="nav-button nav-button-muted"/>
			<Button text="Reminders" onAction="#showRemindersView" maxWidth="Infinity" styleClass="nav-button nav-button-muted"/>
		</VBox>
	</left>
	<center>
		<StackPane fx:id="contentHost" styleClass="content-host" BorderPane.alignment="CENTER"/>
	</center>
	<bottom>
		<HBox spacing="8.0" styleClass="footer-bar" BorderPane.alignment="CENTER_LEFT">
			<padding>
				<Insets top="12.0" right="24.0" bottom="12.0" left="24.0"/>
			</padding>
			<Label fx:id="sectionTitle" text="Chat" styleClass="footer-status"/>
		</HBox>
	</bottom>
</BorderPane>
