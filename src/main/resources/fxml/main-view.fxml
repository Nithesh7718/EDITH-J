<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
            fx:controller="com.edithj.ui.controller.MainController"
            styleClass="app-shell">
    <top>
        <HBox spacing="0" styleClass="app-header" alignment="CENTER_LEFT" BorderPane.alignment="CENTER">
            <padding>
                <Insets top="14.0" right="24.0" bottom="14.0" left="24.0"/>
            </padding>
            <!-- Logo / Title block -->
            <VBox spacing="2.0" alignment="CENTER_LEFT">
                <HBox spacing="6.0" alignment="CENTER_LEFT">
                    <Label text="[ EDITH" styleClass="app-title"/>
                    <Label text="-J ]" styleClass="app-title-accent"/>
                </HBox>
                <Label text="▸  EARLY DEFENSE INTELLIGENCE TARGETING HOST" styleClass="app-subtitle"/>
            </VBox>
            <Region HBox.hgrow="ALWAYS"/>
            <!-- Status indicator -->
            <VBox alignment="CENTER_RIGHT" spacing="4.0">
                <Label text="● SYSTEMS ONLINE" styleClass="status-badge"/>
            </VBox>
        </HBox>
    </top>
    <left>
        <VBox spacing="8.0" prefWidth="200.0" styleClass="sidebar" BorderPane.alignment="TOP_CENTER">
            <padding>
                <Insets top="24.0" right="12.0" bottom="24.0" left="12.0"/>
            </padding>
            <Label text="NAVIGATION" styleClass="sidebar-label"/>
            <Button text="⬡  CHAT" onAction="#showChatView" maxWidth="Infinity" styleClass="nav-button" fx:id="btnChat"/>
            <Button text="▤  NOTES" onAction="#showNotesView" maxWidth="Infinity" styleClass="nav-button-muted" fx:id="btnNotes"/>
            <Button text="⏱  REMINDERS" onAction="#showRemindersView" maxWidth="Infinity" styleClass="nav-button-muted" fx:id="btnReminders"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Label text="BUILD v0.0.8" styleClass="sidebar-label"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentHost" styleClass="content-host" BorderPane.alignment="CENTER"/>
    </center>
    <bottom>
        <HBox spacing="12.0" styleClass="footer-bar" BorderPane.alignment="CENTER_LEFT" alignment="CENTER_LEFT">
            <padding>
                <Insets top="8.0" right="24.0" bottom="8.0" left="24.0"/>
            </padding>
            <Label text="▸" styleClass="footer-status"/>
            <Label fx:id="sectionTitle" text="CHAT" styleClass="footer-status"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="clockLabel" text="--:--:--" styleClass="footer-meta"/>
        </HBox>
    </bottom>
</BorderPane>
