<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
	  fx:controller="com.edithj.ui.controller.ChatController"
	  spacing="16.0" styleClass="chat-panel">
	<padding>
		<Insets top="20.0" right="24.0" bottom="20.0" left="24.0"/>
	</padding>
	<ListView fx:id="messagesList" VBox.vgrow="ALWAYS" styleClass="chat-history"/>
	<HBox spacing="12.0">
		<TextArea fx:id="messageInput" promptText="Type a message..." wrapText="true" prefRowCount="4"
				  HBox.hgrow="ALWAYS" styleClass="chat-input"/>
		<Button text="Send" onAction="#sendMessage" minWidth="120.0" styleClass="primary-button"/>
	</HBox>
</VBox>
