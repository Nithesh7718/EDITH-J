<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21"
      fx:controller="com.edithj.ui.controller.ChatController"
      spacing="12.0" styleClass="chat-panel">
    <padding>
        <Insets top="16.0" right="20.0" bottom="16.0" left="20.0"/>
    </padding>
    <ListView fx:id="messagesList" VBox.vgrow="ALWAYS" styleClass="chat-history"/>
    <HBox spacing="10.0" alignment="CENTER">
        <TextArea fx:id="messageInput"
                  promptText="⟩  INPUT COMMAND OR QUERY..."
                  wrapText="true" prefRowCount="3"
                  HBox.hgrow="ALWAYS" styleClass="chat-input"/>
        <Button text="TRANSMIT" onAction="#sendMessage" prefWidth="110.0" styleClass="send-button"/>
    </HBox>
</VBox>
